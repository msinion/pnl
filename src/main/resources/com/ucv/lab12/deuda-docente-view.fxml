<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DeudaDocenteController"
      spacing="12" style="-fx-padding:18; -fx-background-color:#EEF2F3;">

    <Label text="PNL | Deudas administrativas"
           style="-fx-font-size:22; -fx-font-weight:bold; -fx-text-fill:#263238;">
        <font><Font size="22.0"/></font>
    </Label>
    <Separator/>

    <HBox spacing="10" alignment="CENTER_LEFT"
          style="-fx-background-color:white; -fx-padding:12; -fx-border-color:#CFD8DC;">
        <Label text="Tipo:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtTipoDeuda" promptText="Planilla, reintegro..." prefWidth="170"/>
        <Label text="Fecha:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtFecha" promptText="yyyy-MM-dd" prefWidth="120"/>
        <Label text="Situacion:" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtSituacion" promptText="Nombrado/Contratado" prefWidth="160"/>
        <Button text="Buscar" onAction="#onBuscar" prefWidth="90"
                style="-fx-background-color:#00A896;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="+ Nueva deuda" onAction="#onCrear" prefWidth="140"
                style="-fx-background-color:#00A896;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
        <Button text="Eliminar seleccionadas" onAction="#onEliminarSeleccionados" prefWidth="180"
                style="-fx-background-color:#EF476F;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
        <Button text="Exportar PDF" onAction="#onExportarPdf" prefWidth="120"
                style="-fx-background-color:#F9A826;-fx-text-fill:#263238;-fx-cursor:hand;-fx-font-weight:bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblTotal" text="Total: 0 deuda(s)" style="-fx-font-style:italic; -fx-text-fill:#555;"/>
    </HBox>

    <TableView fx:id="tableView" editable="true" VBox.vgrow="ALWAYS"
               style="-fx-background-color:white; -fx-border-color:#B0BEC5;">
        <columns>
            <TableColumn fx:id="colSeleccion" text="" prefWidth="42" maxWidth="42" resizable="false"/>
            <TableColumn fx:id="colId" text="ID" prefWidth="45" style="-fx-alignment:CENTER;"/>
            <TableColumn fx:id="colDni" text="DNI" prefWidth="90"/>
            <TableColumn fx:id="colDocente" text="Docente" prefWidth="190"/>
            <TableColumn fx:id="colTipo" text="Tipo de deuda" prefWidth="130"/>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="100"/>
            <TableColumn fx:id="colMonto" text="Monto" prefWidth="90"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="105"/>
            <TableColumn fx:id="colSituacion" text="Situacion laboral" prefWidth="130"/>
            <TableColumn fx:id="colAcciones" text="Acciones" prefWidth="155" style="-fx-alignment:CENTER;"/>
        </columns>
        <placeholder><Label text="No hay deudas registradas." style="-fx-text-fill:#888;"/></placeholder>
    </TableView>
</VBox>
