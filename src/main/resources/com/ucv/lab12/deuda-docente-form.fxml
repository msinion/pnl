<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DeudaDocenteFormController"
      spacing="14" style="-fx-padding:24; -fx-background-color:#FAFBFB;" prefWidth="520">

    <Label fx:id="lblTitulo" text="Deuda docente"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#263238;">
        <font><Font size="20"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="140" prefWidth="150" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="280"/>
        </columnConstraints>

        <Label text="DNI docente: *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtDni" promptText="Ingrese DNI" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="Docente: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtDocente" promptText="Apellidos y nombres" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Tipo de deuda: *" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtTipo" promptText="Planilla, reintegro, descuento" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Fecha: *" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtFecha" promptText="yyyy-MM-dd" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Monto S/: *" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <TextField fx:id="txtMonto" promptText="0.00" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

        <Label text="Estado:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cboEstado" GridPane.rowIndex="5" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Situacion laboral:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cboSituacion" GridPane.rowIndex="6" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Observacion:" GridPane.rowIndex="7" GridPane.columnIndex="0" GridPane.valignment="TOP"/>
        <TextArea fx:id="txtObservacion" promptText="Detalle administrativo" prefHeight="70"
                  wrapText="true" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="lblError" visible="false" style="-fx-text-fill:#EF476F; -fx-font-size:12;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" prefWidth="100"/>
        <Button text="Guardar" onAction="#onGuardar" defaultButton="true" prefWidth="100"
                style="-fx-background-color:#00A896;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>
</VBox>
