<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.ucv.lab12.controller.DocenteFormController"
      spacing="14" style="-fx-padding:24; -fx-background-color:#FAFBFB;" prefWidth="480">

    <Label fx:id="lblTitulo" text="Docente"
           style="-fx-font-size:20; -fx-font-weight:bold; -fx-text-fill:#263238;">
        <font><Font size="20"/></font>
    </Label>
    <Separator/>

    <GridPane hgap="12" vgap="10">
        <columnConstraints>
            <ColumnConstraints minWidth="120" prefWidth="130" halignment="RIGHT"/>
            <ColumnConstraints hgrow="ALWAYS" minWidth="260"/>
        </columnConstraints>

        <Label text="Nombres: *" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtNombres" promptText="Apellidos y nombres" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

        <Label text="DNI: *" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight:bold;"/>
        <TextField fx:id="txtDni" promptText="8 digitos" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

        <Label text="Celular:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
        <TextField fx:id="txtCelular" promptText="Contacto" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

        <Label text="Email:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
        <TextField fx:id="txtEmail" promptText="correo@ugel.gob.pe" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

        <Label text="Situacion:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
        <ComboBox fx:id="cboSituacion" GridPane.rowIndex="4" GridPane.columnIndex="1" maxWidth="Infinity"/>

        <Label text="Activo:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
        <CheckBox fx:id="chkActivo" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
    </GridPane>

    <Label fx:id="lblError" visible="false" style="-fx-text-fill:#EF476F; -fx-font-size:12;"/>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button fx:id="btnCancelar" text="Cancelar" onAction="#onCancelar" prefWidth="100"/>
        <Button text="Guardar" onAction="#onGuardar" defaultButton="true" prefWidth="100"
                style="-fx-background-color:#00A896;-fx-text-fill:white;-fx-cursor:hand;-fx-font-weight:bold;"/>
    </HBox>
</VBox>
